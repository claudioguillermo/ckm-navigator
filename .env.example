# Backend API Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# Qwen (DashScope) API Key
# Get your key from the Alibaba Cloud DashScope console
QWEN_API_KEY=your-dashscope-api-key-here

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Server Port
PORT=3001

# Environment (development | production)
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed origins (recommended in production)
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# Session cookie SameSite policy (lax | strict | none)
# Use "none" for cross-site frontend/backend deployments (requires HTTPS in production)
SESSION_COOKIE_SAMESITE=lax

# Chat web enrichment mode (off | adaptive | always)
# adaptive: use the web when the query looks current/broad or curriculum coverage is thin
# always: fetch supplemental web context for every chat request
WEB_SEARCH_MODE=adaptive

# Web enrichment timeout and result cap
WEB_SEARCH_TIMEOUT_MS=6000
WEB_SEARCH_MAX_RESULTS=4
