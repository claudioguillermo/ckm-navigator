            "clinic": {
                "title": "Nossa Clínica",
                "subtitle": "MetroWest Medical Center",
                "storyTitle": "A História de",
                "storyDesc": "Projetado e desenvolvido pelos médicos residentes de Medicina Interna do MetroWest Medical Center.",
                "missionTitle": "Nossa Missão",
                "missionText": "O EMPOWER-CKM é mais do que apenas uma ferramenta—é uma iniciativa centrada no paciente criada pelos seus médicos. Percebemos que compreender a conexão entre o Coração, os Rins e o Metabolismo pode ser opressor. Este projeto foi desenvolvido para fornecer a você os mesmos insights baseados em evidências que usamos na clínica, traduzidos em um guia que você pode usar em qualquer lugar.<br><br>Esta aplicação é o componente central de um projeto de melhoria da qualidade, intitulado EMPOWER-CKM: Educating and Motivating Patients On Wellness through Effective Resident-led CKM-guidance.<br><br>Nossos objetivos específicos são preencher a lacuna educacional nos cuidados cardiometabólicos, fornecendo recursos padronizados, culturalmente competentes e multilíngues. Nosso objetivo é capacitar tanto pacientes quanto médicos residentes para gerenciar melhor as complexas interseções da saúde cardíaca, renal e metabólica.",
                "teamTitle": "Conheça Seus Médicos Residentes",
                "teamText": "No MetroWest Medical Center, nossos Médicos Residentes estão no coração de nossa clínica ambulatorial. Esses médicos dedicados são especializados em Medicina Interna e estão comprometidos em oferecer um atendimento minucioso, compassivo e de última geração.",
                "teamLink": "Saiba mais sobre nosso programa de residência",
                "appointmentTitle": "Agendar uma Consulta",
                "appointmentDesc": "Fale com nossa equipe para discutir sua saúde cardiometabólica."
            },
            "home": {
                "title": "Bem-vindo ao EMPOWER-CKM",
                "subtitle": "Acompanhe sua jornada para uma melhor saúde cardíaca, renal e metabólica.",
                "heroTitle": "Tudo Está Conectado",
                "heroText": "Pense no seu corpo como uma casa: seus Rins são o encanamento, seu Coração é o sistema elétrico e seu Metabolismo é o suprimento de energia. Quando o encanamento entope, ocorre um curto-circuito na eletricidade. Se o suprimento de energia for instável, tudo funciona com mais dificuldade. O EMPOWER-CKM ajuda você a manter sua casa em ordem.",
                "heroBtn": "Comece a Explorar"
            },
            "anatomy": {
                "title": "Anatomia Interativa",
                "subtitle": "A Conexão CKM",
                "text": "Toque em um órgão para ver como a síndrome CKM o afeta.",
                "organs": {
                    "heart": "Coração",
                    "kidneys": "Rins",
                    "metabolism": "Metabolismo"
                },
                "labels": {
                    "role": "Papel Natural",
                    "problem": "O Problema na CKM",
                    "connection": "A Conexão"
                },
                "details": {
                    "heart": {
                        "title": "O Coração (Elétrico)",
                        "role": "O coração é a bomba do corpo, circulando sangue rico em oxigênio para cada célula.",
                        "problem": "Na síndrome CKM, o excesso de gordura corporal e o alto nível de açúcar no sangue danificam os vasos sanguíneos. Isso força o coração a bombear com mais força contra a pressão alta (Hipertensão).",
                        "connection": "Quando o coração tem dificuldades, não consegue bombear sangue suficiente para os rins, fazendo com que falhem. Isso cria um ciclo vicioso onde os rins falhando causam retenção de líquidos, estressando ainda mais o coração (Insuficiência Cardíaca)."
                    },
                    "kidneys": {
                        "title": "Os Rins (Encanamento)",
                        "role": "Seus rins atuam como o filtro do corpo, removendo resíduos e equilibrando fluidos.",
                        "problem": "A pressão alta e o açúcar elevado no sangue danificam os minúsculos filtros (néfrons) dentro dos rins. Isso leva à Doença Renal Crônica (DRC).",
                        "connection": "Rins danificados não conseguem filtrar o sangue adequadamente, levando ao acúmulo de toxinas e fluidos. Esse excesso de fluido aumenta a pressão arterial, o que, por sua vez, causa ainda mais danos ao coração e aos rins."
                    },
                    "metabolism": {
                        "title": "Metabolismo (Energia)",
                        "role": "O metabolismo ajuda o corpo a converter alimentos em energia e a regular os níveis de açúcar.",
                        "problem": "O excesso de tecido adiposo (gordura corporal) libera substâncias químicas inflamatórias prejudiciais. Isso leva à resistência à insulina e ao Diabetes Tipo 2.",
                        "connection": "Essa disfunção metabólica atua como a 'faísca'. A inflamação danifica os vasos sanguíneos em todos os lugares, causando diretamente a doença cardíaca e o dano renal vistos na síndrome CKM."
                    }
                }
            },
