                                    "cost": {
                                        "generic": false
                                    }
                                }
                            ]
                        },
                        {
                            "id": "team",
                            "name": "Partnering with Your Team",
                            "desc": "Communication strategies, questions to ask, and local resources.",
                            "contentHTML": "\n        <div style=\"padding: 0 8px;\">\n            <div class=\"soft-card\" style=\"margin-bottom: 32px; background: #e3f2fd; padding: 24px; border-radius: 12px;\">\n                <h3 style=\"margin-top: 0; color: #1565c0;\">\ud83d\udde3\ufe0f Questions You Should Ask</h3>\n                <ul style=\"padding-left: 20px; font-size: 16px; line-height: 1.6; margin-bottom: 0;\">\n                    <li style=\"margin-bottom: 12px;\">\"What does this medication do for me specifically?\"</li>\n                    <li style=\"margin-bottom: 12px;\">\"Why am I taking this instead of another option?\"</li>\n                    <li style=\"margin-bottom: 12px;\">\"What side effects should I watch for?\"</li>\n                    <li style=\"margin-bottom: 0;\">\"Can I afford this? Are there cheaper alternatives?\"</li>\n                </ul>\n            </div>\n\n            <div class=\"soft-card\" style=\"margin-bottom: 32px; border-left: 6px solid var(--accent-red); padding: 24px; background: #ffebee;\">\n                <h3 style=\"margin-top: 0; color: var(--accent-red);\">\ud83d\udea8 When to Call 911</h3>\n                <p style=\"margin-bottom: 16px;\">Go to the ER or call 911 if you experience:</p>\n                <ul style=\"padding-left: 20px; font-size: 16px; font-weight: 700; color: #c62828;\">\n                    <li style=\"margin-bottom: 12px;\">Severe allergic reaction (swelling of face/lips/tongue)</li>\n                    <li style=\"margin-bottom: 12px;\">Severe chest pain or pressure</li>\n                    <li style=\"margin-bottom: 0;\">Dark urine combined with severe muscle pain</li>\n                </ul>\n            </div>\n\n            <div class=\"soft-card\" style=\"padding: 24px; border: 1px solid var(--border-soft);\">\n                <h3 style=\"margin-top: 0; margin-bottom: 16px;\">Local Help: MetroWest Meds</h3>\n                <p style=\"font-size: 16px; margin-bottom: 24px;\">Free assistance navigating medication access programs and finding lower costs.</p>\n                <a href=\"https://www.kennedychc.org/metrowestmeds/\" target=\"_blank\" class=\"btn btn-primary\" style=\"display: inline-flex; align-items: center; justify-content: center; text-decoration: none;\">\n                    Visit MetroWest Meds <span style=\"margin-left: 8px;\">\u2197</span>\n                </a>\n            </div>\n        </div>\n    "
                        }
                    ]
                },
                "stageExplorer": {
                    "stages": [
                        {
                            "id": 0,
                            "title": "Stage 0: Peak Health",
                            "desc": "No known risk factors. Your goal is to maintain this state.",
                            "factors": {
                                "weight": "Normal range; no excess abdominal fat.",
                                "sugar": "Normal HbA1c (below 5.7%).",
                                "kidneys": "Normal filtration; no leakage of protein.",
                                "heart": "Normal blood pressure; efficient pumping."
                            }
                        },
                        {
                            "id": 1,
                            "title": "Stage 1: Excess Body Fat",
                            "desc": "The body begins to store excess fat in harmful areas.",
                            "factors": {
                                "weight": "Overweight (BMI 25+) or high waist circumference.",
                                "sugar": "Early markers of inflammation may appear.",
                                "kidneys": "Beginning to filter slightly harder to manage load.",
                                "heart": "Normal pressure, but vessels begin to show early stress."
                            }
                        },
                        {
                            "id": 2,
                            "title": "Stage 2: Metabolic Risk",
                            "desc": "High blood pressure, diabetes, or early kidney disease appear.",
                            "factors": {
